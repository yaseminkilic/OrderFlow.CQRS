@page "/orders/create"
@rendermode InteractiveServer
@inject OrderService OrderService
@inject NavigationManager NavigationManager

<PageTitle>Yeni Siparis</PageTitle>

<h2>Yeni Siparis Olustur</h2>

@if (_error != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @_error
        <button type="button" class="btn-close" @onclick="() => _error = null"></button>
    </div>
}

@if (_success)
{
    <div class="alert alert-success">Siparis basariyla olusturuldu! Yonlendiriliyorsunuz...</div>
}

<div class="card">
    <div class="card-body">
        <EditForm Model="_model" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Musteri Adi</label>
                    <InputText class="form-control" @bind-Value="_model.CustomerName" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">E-posta</label>
                    <InputText class="form-control" @bind-Value="_model.CustomerEmail" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Teslimat Adresi</label>
                <InputTextArea class="form-control" @bind-Value="_model.ShippingAddress" rows="2" />
            </div>

            <div class="mb-3">
                <label class="form-label">Notlar</label>
                <InputTextArea class="form-control" @bind-Value="_model.Notes" rows="2" />
            </div>

            <h4 class="mt-4">Urunler</h4>
            <hr />

            @for (int i = 0; i < _model.Items.Count; i++)
            {
                var index = i;
                <div class="row align-items-end mb-2">
                    <div class="col-md-3">
                        <label class="form-label">Urun Adi</label>
                        <InputText class="form-control" @bind-Value="_model.Items[index].ProductName" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Urun Kodu</label>
                        <InputText class="form-control" @bind-Value="_model.Items[index].ProductCode" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Miktar</label>
                        <InputNumber class="form-control" @bind-Value="_model.Items[index].Quantity" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Birim Fiyat</label>
                        <InputNumber class="form-control" @bind-Value="_model.Items[index].UnitPrice" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Toplam</label>
                        <div class="form-control-plaintext fw-bold">
                            @((_model.Items[index].Quantity * _model.Items[index].UnitPrice).ToString("C2"))
                        </div>
                    </div>
                    <div class="col-md-1">
                        @if (_model.Items.Count > 1)
                        {
                            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => RemoveItem(index)">X</button>
                        }
                    </div>
                </div>
            }

            <button type="button" class="btn btn-outline-secondary mb-3" @onclick="AddItem">+ Urun Ekle</button>

            <div class="border-top pt-3">
                <h5>Genel Toplam: @GetTotal().ToString("C2")</h5>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary" disabled="@_submitting">
                    @if (_submitting)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    Siparis Olustur
                </button>
                <a href="orders" class="btn btn-outline-secondary ms-2">Iptal</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private OrderFormModel _model = new();
    private bool _submitting;
    private bool _success;
    private string? _error;

    protected override void OnInitialized()
    {
        _model.Items.Add(new CreateOrderItemDto());
    }

    private void AddItem()
    {
        _model.Items.Add(new CreateOrderItemDto());
    }

    private void RemoveItem(int index)
    {
        _model.Items.RemoveAt(index);
    }

    private decimal GetTotal()
    {
        return _model.Items.Sum(i => i.Quantity * i.UnitPrice);
    }

    private async Task HandleSubmit()
    {
        _submitting = true;
        _error = null;

        try
        {
            var command = new CreateOrderCommand(
                _model.CustomerName,
                _model.CustomerEmail,
                _model.ShippingAddress,
                _model.Notes,
                _model.Items);

            await OrderService.CreateOrderAsync(command);
            _success = true;

            await Task.Delay(1500);
            NavigationManager.NavigateTo("/orders");
        }
        catch (Exception ex)
        {
            _error = $"Siparis olusturulurken hata: {ex.Message}";
        }
        finally
        {
            _submitting = false;
        }
    }

    private class OrderFormModel
    {
        public string CustomerName { get; set; } = string.Empty;
        public string CustomerEmail { get; set; } = string.Empty;
        public string ShippingAddress { get; set; } = string.Empty;
        public string? Notes { get; set; }
        public List<CreateOrderItemDto> Items { get; set; } = new();
    }
}
