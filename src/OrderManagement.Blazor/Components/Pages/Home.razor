@page "/"

<PageTitle>Order Management</PageTitle>

<h1>Order Management System</h1>

<div class="row mt-4">
    <div class="col-md-4">
        <div class="card bg-primary text-white mb-3">
            <div class="card-body">
                <h5 class="card-title">Siparisler</h5>
                <p class="card-text">Tum siparisleri goruntuleyin ve yonetin.</p>
                <a href="orders" class="btn btn-light">Siparislere Git</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-success text-white mb-3">
            <div class="card-body">
                <h5 class="card-title">Yeni Siparis</h5>
                <p class="card-text">Yeni bir siparis olusturun.</p>
                <a href="orders/create" class="btn btn-light">Siparis Olustur</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-info text-white mb-3">
            <div class="card-body">
                <h5 class="card-title">Sistem Durumu</h5>
                <p class="card-text">API ve RabbitMQ baglanti durumu.</p>
                <span class="badge bg-light text-dark">Aktif</span>
            </div>
        </div>
    </div>
</div>
